{
    "buildCommand": "",
    "outputDirectory": ".",
    "framework": null,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                }
            ]
        },
        {
            "source": "/(.+\\.js)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=60, s-maxage=60"
                }
            ]
        },
        {
            "source": "/(.+\\.css)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=3600"
                }
            ]
        },
        {
            "source": "/(.+\\.html)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=60"
                }
            ]
        }
    ]
}